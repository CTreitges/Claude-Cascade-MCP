# Claude-Cascade — example environment file.
#
# Copy this to `.env` and fill in only what you actually need:
#
#     cp .env.example .env
#
# Or run the guided setup wizard from inside the bot (`/setup` after
# starting it once with at least TELEGRAM_BOT_TOKEN), which writes a
# separate `secrets.env` file that overrides this one. Either workflow
# is fine — the wizard never touches your `.env`.
#
# Defaults that work without secrets are commented out below; uncomment
# only when you want to override them.

# === Telegram ===========================================================
# Get a bot token from @BotFather. Owner ID = your numeric Telegram user
# id (any "@userinfobot" gives it to you).
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
# Bot language: de or en (default de)
# CASCADE_BOT_LANG=de

# === Implementer (Cloud LLM) ===========================================
# Provider: ollama | openai_compatible | claude
# CASCADE_IMPLEMENTER_PROVIDER=ollama
# CASCADE_IMPLEMENTER_MODEL=qwen3-coder:480b
# CASCADE_IMPLEMENTER_TOOLS=fileops

# Ollama Cloud — get an API key at https://ollama.com/account
# OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_CLOUD_API_KEY=

# OpenAI-compatible providers (any subset). Pick the implementer model
# accordingly: glm-* / deepseek-* / minimax-* / kimi-*.
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=

# === OpenAI (Whisper voice + optional implementer) =====================
# Required if you want voice messages transcribed.
OPENAI_API_KEY=

# === External research =================================================
# Brave Search — free key from https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=
# CASCADE_CONTEXT7_ENABLED=true
# CASCADE_WEBSEARCH_ENABLED=true

# === Planner / Reviewer (Claude CLI) ===================================
# Requires a working `claude` CLI on $PATH (Max-Subscription).
# CASCADE_PLANNER_MODEL=claude-opus-4-7
# CASCADE_REVIEWER_MODEL=claude-sonnet-4-6
# CASCADE_TRIAGE_MODEL=claude-sonnet-4-6
# CASCADE_TRIAGE_ENABLED=true

# === Runtime ===========================================================
# Where the bot stores DB / workspaces / logs. Default: ~/claude-cascade
# CASCADE_HOME=
# CASCADE_TIMEZONE=Europe/Berlin

# Iteration cap — set to 999 (effectively unlimited) by default; only
# LLM-usage / rate-limit budget should stop a run. Stagnation-detection
# in core.py prevents endless identical-diff loops.
# CASCADE_MAX_ITERATIONS=999
# CASCADE_REPLAN_AFTER_FAILURES=2
# CASCADE_REPLAN_MAX=2

# CASCADE_AUTO_SKILL_SUGGEST=true
# CASCADE_SKILL_SUGGEST_COOLDOWN_S=300
# CASCADE_WORKSPACE_RETENTION_DAYS=7
# CASCADE_DB_PATH=

# === Chat-Memory + Logging =============================================
# Verbose logging (RotatingFileHandler under store/debug.log, 10MB × 5).
# Console stays at INFO unless this is on.
# CASCADE_DEBUG=false
# Background chat-summariser: condenses old messages into chat_summaries
# rows so build_context() can carry long-term anchors without dumping
# raw history into every prompt.
# CASCADE_SUMMARIZE_ENABLED=true
# CASCADE_SUMMARIZE_TICK_S=21600

# === Auto-Resume =======================================================
# Bot resumes interrupted tasks on startup? Inline-keyboard offers
# Continue / Restart / Cancel for matching new tasks regardless.
# CASCADE_AUTO_RESUME_INTERRUPTED=false

# === Multi-Plan-Voting (opt-in, doubles planner cost) ==================
# CASCADE_MULTIPLAN_ENABLED=false
