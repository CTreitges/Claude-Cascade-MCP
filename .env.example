# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
# Bot-Sprache: de oder en (Default de)
CASCADE_BOT_LANG=de

# --- Implementer (Cloud LLM) ---
# Provider: ollama | openai_compatible
CASCADE_IMPLEMENTER_PROVIDER=ollama
CASCADE_IMPLEMENTER_MODEL=qwen3-coder:480b
# Tool mode: fileops | mcp
CASCADE_IMPLEMENTER_TOOLS=fileops

# Ollama Cloud
OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_CLOUD_API_KEY=

# OpenAI-compatible providers (any subset, choose via implementer-config)
# Each entry: BASE_URL + API_KEY. Implementer model selects which is used.
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=

# --- Whisper (Voice transcription via OpenAI) ---
OPENAI_API_KEY=

# --- Planner / Reviewer (Claude CLI) ---
CASCADE_PLANNER_MODEL=claude-opus-4-7
CASCADE_REVIEWER_MODEL=claude-sonnet-4-6
# Triage entscheidet bei Bot-Messages "Task vs. Konversation". Fallback auf Heuristik wenn der Claude-Call scheitert.
CASCADE_TRIAGE_MODEL=claude-sonnet-4-6
CASCADE_TRIAGE_ENABLED=true

# --- Runtime ---
CASCADE_HOME=/home/chris/claude-cascade
CASCADE_MAX_ITERATIONS=3
CASCADE_WORKSPACE_RETENTION_DAYS=7
CASCADE_DB_PATH=/home/chris/claude-cascade/store/cascade.db
